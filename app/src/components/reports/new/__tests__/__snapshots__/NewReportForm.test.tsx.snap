                    aria-label="Zoom in"
                    class="leaflet-control-zoom-in"
                    href="#"
                    role="button"
                    title="Zoom in"
                  >
                    <span
                      aria-hidden="true"
                    >
                      +
                    </span>
                  </a>
                  <a
                    aria-disabled="false"
